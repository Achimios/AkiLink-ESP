# ===================================================================
#  sdkconfig.defaults - MAVLink low-rate high-reliability preset
# ===================================================================
#
#  PlatformIO merges this file into sdkconfig.esp32dev on first build.
#  Run `pio run -t menuconfig` for interactive editing.
#
#  Strategy: shallow queues + no power save + 11b + moderate buffers
# ===================================================================

# ----------- Flash -----------
# DIO mode (QIO causes crashes on this board)
CONFIG_ESPTOOLPY_FLASHMODE_DIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y

# ----------- FreeRTOS -----------
# 1000 Hz tick -> vTaskDelay(1) = 1 ms (default is 10 ms)
CONFIG_FREERTOS_HZ=1000

# Main task stack (default 3584 may be too small with WiFi init)
CONFIG_ESP_MAIN_TASK_STACK_SIZE=4096

# ----------- WiFi Driver -----------
CONFIG_ESP32_WIFI_SW_COEXIST_ENABLE=y

# TX buffers (driver-level send queue, dynamic = allocate on demand)
CONFIG_ESP32_WIFI_DYNAMIC_TX_BUFFER=y
CONFIG_ESP32_WIFI_DYNAMIC_TX_BUFFER_NUM=32
CONFIG_ESP32_WIFI_STATIC_TX_BUFFER_NUM=32

# RX buffers
CONFIG_ESP32_WIFI_STATIC_RX_BUFFER_NUM=32
CONFIG_ESP32_WIFI_DYNAMIC_RX_BUFFER_NUM=32

# AMPDU: 11b does not support AMPDU, disable to save memory
CONFIG_ESP32_WIFI_AMPDU_TX_ENABLED=n
CONFIG_ESP32_WIFI_AMPDU_RX_ENABLED=n

# IRAM opt: put WiFi hot-path into IRAM to reduce flash cache-miss jitter
CONFIG_ESP_WIFI_IRAM_OPT=y
CONFIG_ESP_WIFI_EXTRA_IRAM_OPT=y
CONFIG_ESP_WIFI_RX_IRAM_OPT=y

# NVS stores RF calibration data (faster boot)
CONFIG_ESP32_WIFI_NVS_ENABLED=y

# ----------- lwIP Core -----------
CONFIG_LWIP_IRAM_OPTIMIZATION=y

# tcpip_thread priority (keep below app tasks)
CONFIG_LWIP_TCPIP_TASK_PRIO=20

# tcpip_thread input queue depth
CONFIG_LWIP_TCPIP_RECVMBOX_SIZE=32

# ----------- lwIP UDP -----------
# Max simultaneous UDP PCBs (1-2 used here, 4 is fine)
CONFIG_LWIP_MAX_UDP_PCBS=4

# UDP receive mailbox (BSD socket path; small effect on RAW path)
CONFIG_LWIP_UDP_RECVMBOX_SIZE=16

# ----------- lwIP TCP -----------
# Kept at moderate values even though UDP is the primary protocol

CONFIG_LWIP_TCP_RECVMBOX_SIZE=16
CONFIG_LWIP_TCP_ACCEPTMBOX_SIZE=6

# Send buffer & receive window (avoid giant queues that add latency)
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=16384
CONFIG_LWIP_TCP_WND_DEFAULT=8192

# MSS 1200: robust middle ground (WiFi MTU 1500, no fragmentation)
CONFIG_LWIP_TCP_MSS=1200

# Timer interval 250 ms: conservative, avoids layering with MAVLink retx
CONFIG_LWIP_TCP_TMR_INTERVAL=250

# Retransmit limits: give up fast so the app layer can send fresh data
CONFIG_LWIP_TCP_MAXRTX=6
CONFIG_LWIP_TCP_SYNMAXRTX=4

# ----------- Watchdog -----------
CONFIG_ESP_TASK_WDT_EN=y
CONFIG_ESP_TASK_WDT_TIMEOUT_S=10
